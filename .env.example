# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/roomreport?sslmode=require"

# Server
PORT=3000
NODE_ENV=development
USE_SECURE_COOKIES=false  # Set to true when using HTTPS

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# App URL (your domain or IP, used for CORS)
APP_URL="http://localhost:5173"

# DigitalOcean Spaces (S3-compatible storage)
DO_SPACES_KEY="your-spaces-access-key"
DO_SPACES_SECRET="your-spaces-secret-key"
DO_SPACES_REGION="nyc3"
DO_SPACES_BUCKET="roomreport"
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"

# SendGrid (transactional email — team invites, notifications)
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="hello@roomreport.co"
SENDGRID_FROM_NAME="RoomReport"

# Client
VITE_API_URL=http://localhost:3000
