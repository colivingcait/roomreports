generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  OWNER
  PM
  CLEANER
  HANDYPERSON
  RESIDENT
  OTHER
}

enum InspectionType {
  COMMON_AREA
  COMMON_AREA_QUICK
  ROOM_TURN
  QUARTERLY
  RESIDENT_SELF_CHECK
  MOVE_IN_OUT
}

enum InspectionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  DEFERRED
}

enum DeferType {
  ROOM_TURN
  DATE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Plan {
  STARTER
  GROWTH
  OPERATOR
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// Notification "type" is stored as a free-form string (see the catalog
// in shared/notifications.js). Each type is styled/iconed on the
// client and gated per-user for email delivery via NotificationPreference.

// ─── Organization ───────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  timezone  String?
  plan      Plan     @default(OPERATOR)
  isBeta    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users       User[]
  properties  Property[]
  inspections Inspection[]
  maintenanceItems MaintenanceItem[]
  invitations Invitation[]
  vendors     Vendor[]
  notifications Notification[]
  financialUploads  FinancialUpload[]
  financialRecords  FinancialRecord[]
  padSplitMappings  PadSplitPropertyMapping[]

  @@map("organizations")
}

// ─── User ───────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String?
  googleId       String?  @unique
  role           Role
  customRole     String?
  organizationId String
  assignToAllProperties Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id])
  sessions            Session[]
  inspections         Inspection[]
  propertyAssignments PropertyAssignment[]
  sentInvitations     Invitation[]         @relation("InvitedByUser")
  assignedMaintenance MaintenanceItem[]    @relation("AssignedUser")
  notifications       Notification[]
  notificationPreferences NotificationPreference[]
  passwordResetTokens PasswordResetToken[]

  @@index([organizationId])
  @@map("users")
}

// ─── Session ────────────────────────────────────────────

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Invitation ─────────────────────────────────────────

model Invitation {
  id             String           @id @default(cuid())
  email          String
  name           String?
  role           Role
  customRole     String?
  token          String           @unique
  organizationId String
  propertyId     String?
  propertyIds    String[]         @default([])
  assignToAllProperties Boolean   @default(false)
  roomId         String?
  invitedById    String
  status         InvitationStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  lastSentAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  room         Room?        @relation(fields: [roomId], references: [id])
  invitedBy    User         @relation("InvitedByUser", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([token])
  @@index([email])
  @@map("invitations")
}

// ─── Property ───────────────────────────────────────────

model Property {
  id             String   @id @default(cuid())
  name           String
  address        String
  metroArea      String?
  imageUrl       String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id])
  rooms               Room[]
  kitchens            Kitchen[]
  bathrooms           Bathroom[]
  inspections         Inspection[]
  maintenanceItems    MaintenanceItem[]
  propertyAssignments PropertyAssignment[]
  invitations         Invitation[]

  @@index([organizationId])
  @@map("properties")
}

// ─── Room ───────────────────────────────────────────────

model Room {
  id              String   @id @default(cuid())
  label           String
  features        String[]
  furniture       String[]
  propertyId      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastTurnoverAt  DateTime?
  deletedAt       DateTime?

  property         Property          @relation(fields: [propertyId], references: [id])
  inspections      Inspection[]
  maintenanceItems MaintenanceItem[]
  invitations      Invitation[]

  @@index([propertyId])
  @@map("rooms")
}

// ─── Kitchen ────────────────────────────────────────────

model Kitchen {
  id         String   @id @default(cuid())
  label      String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@map("kitchens")
}

// ─── Bathroom ───────────────────────────────────────────

model Bathroom {
  id         String   @id @default(cuid())
  label      String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@map("bathrooms")
}

// ─── PropertyAssignment ─────────────────────────────────

model PropertyAssignment {
  id         String @id @default(cuid())
  userId     String
  propertyId String

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
  @@map("property_assignments")
}

// ─── Inspection ─────────────────────────────────────────

model Inspection {
  id             String           @id @default(cuid())
  type           InspectionType
  status         InspectionStatus @default(DRAFT)
  propertyId     String
  roomId         String?
  inspectorId    String
  inspectorName  String
  inspectorRole  Role
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  completedAt    DateTime?
  editedAt       DateTime?
  editCount      Int              @default(0)
  deletedAt      DateTime?
  residentEmail  String?
  residentNotifyOptIn Boolean     @default(false)

  property         Property          @relation(fields: [propertyId], references: [id])
  room             Room?             @relation(fields: [roomId], references: [id])
  inspector        User              @relation(fields: [inspectorId], references: [id])
  organization     Organization      @relation(fields: [organizationId], references: [id])
  items            InspectionItem[]
  maintenanceItems MaintenanceItem[]
  edits            InspectionEdit[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([inspectorId])
  @@map("inspections")
}

// ─── InspectionEdit ─────────────────────────────────────
// One row per reopen-to-edit event, so review pages can show a full
// "edited by X on Y" history rather than just the latest timestamp.

model InspectionEdit {
  id            String   @id @default(cuid())
  inspectionId  String
  editorId      String
  editorName    String
  editorRole    String
  editedAt      DateTime @default(now())

  inspection    Inspection @relation(fields: [inspectionId], references: [id])

  @@index([inspectionId])
  @@map("inspection_edits")
}

// ─── InspectionItem ─────────────────────────────────────

model InspectionItem {
  id               String   @id @default(cuid())
  inspectionId     String
  zone             String
  text             String
  options          String[]
  status           String
  flagCategory     String?
  note             String?
  isMaintenance    Boolean  @default(false)
  isLeaseViolation Boolean  @default(false)
  priority         String?
  entryCode        String?
  entryApproved    Boolean  @default(false)
  createdAt        DateTime @default(now())

  inspection      Inspection       @relation(fields: [inspectionId], references: [id])
  maintenanceItem MaintenanceItem?
  photos          Photo[]

  @@index([inspectionId])
  @@map("inspection_items")
}

// ─── MaintenanceItem ────────────────────────────────────

model MaintenanceItem {
  id                String            @id @default(cuid())
  inspectionItemId  String?           @unique
  inspectionId      String?
  propertyId        String
  roomId            String?
  organizationId    String
  description       String
  zone              String
  status            MaintenanceStatus @default(OPEN)
  assignedTo        String?           // free-text (custom / legacy)
  assignedUserId    String?
  assignedVendorId  String?
  flagCategory      String
  note              String?
  priority          String?           // Low | Medium | High
  estimatedCost     Float?
  actualCost        Float?
  vendor            String?
  entryApproved     Boolean           @default(false)
  entryApprovedAt   DateTime?
  entryCode         String?
  reportedById      String?
  reportedByName    String?
  reportedByRole    String?
  reporterEmail     String?
  reporterNotifyOptIn Boolean         @default(false)
  trackingToken     String?           @unique
  reporterUnsubscribed Boolean        @default(false)
  lastOverdueNotifiedAt DateTime?
  deferType         DeferType?
  deferUntil        DateTime?
  deferReason       String?
  deferredAt        DateTime?
  deferredById      String?
  deferredByName    String?
  reactivatedAt     DateTime?
  reactivatedReason String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  resolvedAt        DateTime?
  archivedAt        DateTime?
  deletedAt         DateTime?
  parentTicketId    String?
  mergedAt          DateTime?
  isLeaseFollowUp   Boolean   @default(false)
  leaseViolationId  String?
  dueAt             DateTime?
  dueNotifiedAt     DateTime?

  parent          MaintenanceItem?        @relation("MergedTickets", fields: [parentTicketId], references: [id])
  children        MaintenanceItem[]       @relation("MergedTickets")
  inspectionItem  InspectionItem?         @relation(fields: [inspectionItemId], references: [id])
  inspection      Inspection?             @relation(fields: [inspectionId], references: [id])
  property        Property                @relation(fields: [propertyId], references: [id])
  room            Room?                   @relation(fields: [roomId], references: [id])
  organization    Organization            @relation(fields: [organizationId], references: [id])
  assignedUser    User?                   @relation("AssignedUser", fields: [assignedUserId], references: [id])
  assignedVendor  Vendor?                 @relation(fields: [assignedVendorId], references: [id])
  photos          Photo[]
  attachments     MaintenanceAttachment[]
  events          MaintenanceEvent[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([status])
  @@index([assignedVendorId])
  @@index([assignedUserId])
  @@index([trackingToken])
  @@index([deferUntil])
  @@index([parentTicketId])
  @@map("maintenance_items")
}

// ─── Vendor ─────────────────────────────────────────────

model Vendor {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  company        String?
  phone          String?
  email          String?
  specialties    String[] // FLAG_CATEGORIES values
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization        Organization      @relation(fields: [organizationId], references: [id])
  assignedMaintenance MaintenanceItem[]

  @@index([organizationId])
  @@map("vendors")
}

// ─── MaintenanceAttachment ──────────────────────────────

model MaintenanceAttachment {
  id                String   @id @default(cuid())
  maintenanceItemId String
  url               String
  key               String
  label             String   // quote | receipt | invoice | other
  originalName      String
  contentType       String?
  createdAt         DateTime @default(now())

  maintenance MaintenanceItem @relation(fields: [maintenanceItemId], references: [id])

  @@index([maintenanceItemId])
  @@map("maintenance_attachments")
}

// ─── MaintenanceEvent ───────────────────────────────────

model MaintenanceEvent {
  id                String   @id @default(cuid())
  maintenanceItemId String
  type              String   // created | status | assigned | priority | note | cost | vendor | attachment | resolved | reopened
  fromValue         String?
  toValue           String?
  note              String?
  byUserId          String?
  byUserName        String?
  createdAt         DateTime @default(now())

  maintenance MaintenanceItem @relation(fields: [maintenanceItemId], references: [id])

  @@index([maintenanceItemId])
  @@map("maintenance_events")
}

// ─── LeaseViolation ─────────────────────────────────────

model LeaseViolation {
  id               String    @id @default(cuid())
  organizationId   String
  propertyId       String
  roomId           String?
  inspectionId     String?
  inspectionItemId String?   @unique
  description      String
  category         String?
  note             String?
  reportedById     String?
  reportedByName   String?
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?
  archivedAt       DateTime?
  archivedReason   String?
  deletedAt        DateTime?

  actions LeaseViolationAction[]

  @@index([organizationId])
  @@index([propertyId])
  @@map("lease_violations")
}

// ─── LeaseViolationAction ───────────────────────────────
// Follow-up actions logged against a violation (paper trail)

model LeaseViolationAction {
  id                String   @id @default(cuid())
  leaseViolationId  String
  organizationId    String
  method            String   // text | email | verbal | written_notice | other
  description       String
  actionAt          DateTime @default(now())
  loggedById        String?
  loggedByName      String?
  createdAt         DateTime @default(now())

  violation LeaseViolation @relation(fields: [leaseViolationId], references: [id])

  @@index([leaseViolationId])
  @@index([organizationId])
  @@map("lease_violation_actions")
}

// ─── Task ───────────────────────────────────────────────
// Admin task board — separate from MaintenanceItem

model Task {
  id               String     @id @default(cuid())
  organizationId   String
  title            String
  description      String?
  propertyId       String?
  assignedTo       String?
  assignedUserId   String?
  assignedVendorId String?
  dueAt            DateTime?
  priority         String?    // Low | Medium | High
  status           TaskStatus @default(TODO)
  createdById      String?
  createdByName    String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  completedAt      DateTime?
  deletedAt        DateTime?

  @@index([organizationId])
  @@index([propertyId])
  @@index([assignedUserId])
  @@index([assignedVendorId])
  @@index([status])
  @@map("tasks")
}

// ─── InspectionSchedule ─────────────────────────────────
// Recurrence rule per property + inspection type

model InspectionSchedule {
  id              String         @id @default(cuid())
  organizationId  String
  propertyId      String
  inspectionType  InspectionType
  frequencyDays   Int            // e.g. 7, 14, 30, 90
  startsOn        DateTime       @default(now())
  active          Boolean        @default(true)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([propertyId, inspectionType])
  @@index([organizationId])
  @@map("inspection_schedules")
}

// ─── InspectionTemplate ─────────────────────────────────
// Per-org, per-type customization of the built-in checklist.

model InspectionTemplate {
  id             String         @id @default(cuid())
  organizationId String
  inspectionType InspectionType
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  items InspectionTemplateItem[]

  @@unique([organizationId, inspectionType])
  @@map("inspection_templates")
}

model InspectionTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  zone       String
  text       String
  options    String[]
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("inspection_template_items")
}

// ─── Suggestion ─────────────────────────────────────────

model Suggestion {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  userName       String
  userEmail      String
  text           String
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("suggestions")
}

// ─── Photo ──────────────────────────────────────────────

model Photo {
  id                String  @id @default(cuid())
  url               String
  key               String
  inspectionItemId  String?
  maintenanceItemId String?
  createdAt         DateTime @default(now())

  inspectionItem  InspectionItem?  @relation(fields: [inspectionItemId], references: [id])
  maintenanceItem MaintenanceItem? @relation(fields: [maintenanceItemId], references: [id])

  @@index([inspectionItemId])
  @@index([maintenanceItemId])
  @@map("photos")
}

// ─── Notification ───────────────────────────────────────

model Notification {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  type           String
  title          String
  message        String
  link           String?
  read           Boolean  @default(false)
  readAt         DateTime?
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([userId, read, createdAt])
  @@index([organizationId])
  @@map("notifications")
}

// ─── FinancialUpload ────────────────────────────────────
// One per (org, earningsMonth) — represents a single PadSplit
// monthly report upload. Reuploading the same month overwrites
// prior records via cascade delete on FinancialRecord.

model FinancialUpload {
  id             String   @id @default(cuid())
  organizationId String
  earningsMonth  String   // "YYYY-MM"
  uploadedAt     DateTime @default(now())
  uploadedById   String?
  fileNames      String[] @default([])

  organization Organization      @relation(fields: [organizationId], references: [id])
  records      FinancialRecord[]

  @@unique([organizationId, earningsMonth])
  @@index([organizationId])
  @@map("financial_uploads")
}

// ─── FinancialRecord ────────────────────────────────────
// Normalized rows parsed out of summary.csv, collected.csv,
// billed.csv, earnings_table.csv. Categorized by recordType.

model FinancialRecord {
  id              String   @id @default(cuid())
  uploadId        String
  organizationId  String
  earningsMonth   String   // "YYYY-MM"
  recordType      String   // SUMMARY | COLLECTED | BILLED | EARNINGS_TABLE
  propertyAddress String?
  propertyPSID    String?
  roomNumber      String?
  roomId          String?
  memberId        String?
  memberName      String?
  billType        String?  // membership_dues | late_fees | concession | ...
  transactionType String?
  transactionReason String?
  billId          String?
  grossAmount     Float?
  bookingFee      Float?
  serviceFee      Float?
  transactionFee  Float?
  hostEarnings    Float?
  totalCollections Float?
  totalExpenses    Float?
  totalPayout      Float?
  category        String?
  rowType         String?
  recordDate      DateTime?
  createdAt       DateTime @default(now())

  upload       FinancialUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  organization Organization    @relation(fields: [organizationId], references: [id])

  @@index([organizationId, earningsMonth])
  @@index([uploadId])
  @@index([propertyAddress])
  @@index([roomNumber])
  @@map("financial_records")
}

// ─── PadSplitPropertyMapping ───────────────────────────
// Maps a PadSplit street address (from CSVs) to a RoomReport
// Property. Stored per-org so we don't re-fuzzy-match every load.

model PadSplitPropertyMapping {
  id             String   @id @default(cuid())
  organizationId String
  padsplitAddress String  // normalized street, e.g. "2136 chestnut hill cir"
  propertyId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, padsplitAddress])
  @@index([organizationId])
  @@index([propertyId])
  @@map("padsplit_property_mappings")
}

// ─── PasswordResetToken ─────────────────────────────────
// Single-use, time-limited tokens for the forgot-password flow.

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

// ─── NotificationPreference ─────────────────────────────
// One row per (user, type). Missing rows fall back to the per-type
// default in shared/notifications.js.

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  type      String
  email     Boolean  @default(true)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("notification_preferences")
}
