generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  OWNER
  PM
  CLEANER
  HANDYPERSON
  RESIDENT
  OTHER
}

enum InspectionType {
  COMMON_AREA
  ROOM_TURN
  QUARTERLY
  RESIDENT_SELF_CHECK
  MOVE_IN_OUT
}

enum InspectionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

// ─── Organization ───────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users       User[]
  properties  Property[]
  inspections Inspection[]
  maintenanceItems MaintenanceItem[]
  invitations Invitation[]

  @@map("organizations")
}

// ─── User ───────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String?
  googleId       String?  @unique
  role           Role
  customRole     String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id])
  sessions            Session[]
  inspections         Inspection[]
  propertyAssignments PropertyAssignment[]
  sentInvitations     Invitation[]         @relation("InvitedByUser")

  @@index([organizationId])
  @@map("users")
}

// ─── Session ────────────────────────────────────────────

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Invitation ─────────────────────────────────────────

model Invitation {
  id             String   @id @default(cuid())
  email          String
  role           Role
  token          String   @unique
  organizationId String
  propertyId     String?
  roomId         String?
  invitedById    String
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  room         Room?        @relation(fields: [roomId], references: [id])
  invitedBy    User         @relation("InvitedByUser", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([token])
  @@map("invitations")
}

// ─── Property ───────────────────────────────────────────

model Property {
  id             String   @id @default(cuid())
  name           String
  address        String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id])
  rooms               Room[]
  kitchens            Kitchen[]
  bathrooms           Bathroom[]
  inspections         Inspection[]
  maintenanceItems    MaintenanceItem[]
  propertyAssignments PropertyAssignment[]
  invitations         Invitation[]

  @@index([organizationId])
  @@map("properties")
}

// ─── Room ───────────────────────────────────────────────

model Room {
  id        String   @id @default(cuid())
  label     String
  features  String[]
  furniture String[]
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  property         Property          @relation(fields: [propertyId], references: [id])
  inspections      Inspection[]
  maintenanceItems MaintenanceItem[]
  invitations      Invitation[]

  @@index([propertyId])
  @@map("rooms")
}

// ─── Kitchen ────────────────────────────────────────────

model Kitchen {
  id         String   @id @default(cuid())
  label      String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@map("kitchens")
}

// ─── Bathroom ───────────────────────────────────────────

model Bathroom {
  id         String   @id @default(cuid())
  label      String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@map("bathrooms")
}

// ─── PropertyAssignment ─────────────────────────────────

model PropertyAssignment {
  id         String @id @default(cuid())
  userId     String
  propertyId String

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
  @@map("property_assignments")
}

// ─── Inspection ─────────────────────────────────────────

model Inspection {
  id             String           @id @default(cuid())
  type           InspectionType
  status         InspectionStatus @default(DRAFT)
  propertyId     String
  roomId         String?
  inspectorId    String
  inspectorName  String
  inspectorRole  Role
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  completedAt    DateTime?
  deletedAt      DateTime?

  property         Property          @relation(fields: [propertyId], references: [id])
  room             Room?             @relation(fields: [roomId], references: [id])
  inspector        User              @relation(fields: [inspectorId], references: [id])
  organization     Organization      @relation(fields: [organizationId], references: [id])
  items            InspectionItem[]
  maintenanceItems MaintenanceItem[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([inspectorId])
  @@map("inspections")
}

// ─── InspectionItem ─────────────────────────────────────

model InspectionItem {
  id               String   @id @default(cuid())
  inspectionId     String
  zone             String
  text             String
  options          String[]
  status           String
  flagCategory     String?
  note             String?
  isMaintenance    Boolean  @default(false)
  isLeaseViolation Boolean  @default(false)
  priority         String?
  entryCode        String?
  entryApproved    Boolean  @default(false)
  createdAt        DateTime @default(now())

  inspection      Inspection       @relation(fields: [inspectionId], references: [id])
  maintenanceItem MaintenanceItem?
  photos          Photo[]

  @@index([inspectionId])
  @@map("inspection_items")
}

// ─── MaintenanceItem ────────────────────────────────────

model MaintenanceItem {
  id                String            @id @default(cuid())
  inspectionItemId  String            @unique
  inspectionId      String
  propertyId        String
  roomId            String?
  organizationId    String
  description       String
  zone              String
  status            MaintenanceStatus @default(OPEN)
  assignedTo        String?
  flagCategory      String
  note              String?
  priority          String?           // Low | Medium | High
  estimatedCost     Float?
  actualCost        Float?
  vendor            String?
  entryApproved     Boolean           @default(false)
  entryApprovedAt   DateTime?
  entryCode         String?
  reportedById      String?
  reportedByName    String?
  reportedByRole    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  resolvedAt        DateTime?
  deletedAt         DateTime?

  inspectionItem InspectionItem          @relation(fields: [inspectionItemId], references: [id])
  inspection     Inspection              @relation(fields: [inspectionId], references: [id])
  property       Property                @relation(fields: [propertyId], references: [id])
  room           Room?                   @relation(fields: [roomId], references: [id])
  organization   Organization            @relation(fields: [organizationId], references: [id])
  photos         Photo[]
  attachments    MaintenanceAttachment[]
  events         MaintenanceEvent[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([status])
  @@map("maintenance_items")
}

// ─── MaintenanceAttachment ──────────────────────────────

model MaintenanceAttachment {
  id                String   @id @default(cuid())
  maintenanceItemId String
  url               String
  key               String
  label             String   // quote | receipt | invoice | other
  originalName      String
  contentType       String?
  createdAt         DateTime @default(now())

  maintenance MaintenanceItem @relation(fields: [maintenanceItemId], references: [id])

  @@index([maintenanceItemId])
  @@map("maintenance_attachments")
}

// ─── MaintenanceEvent ───────────────────────────────────

model MaintenanceEvent {
  id                String   @id @default(cuid())
  maintenanceItemId String
  type              String   // created | status | assigned | priority | note | cost | vendor | attachment | resolved | reopened
  fromValue         String?
  toValue           String?
  note              String?
  byUserId          String?
  byUserName        String?
  createdAt         DateTime @default(now())

  maintenance MaintenanceItem @relation(fields: [maintenanceItemId], references: [id])

  @@index([maintenanceItemId])
  @@map("maintenance_events")
}

// ─── LeaseViolation ─────────────────────────────────────

model LeaseViolation {
  id               String    @id @default(cuid())
  organizationId   String
  propertyId       String
  roomId           String?
  inspectionId     String
  inspectionItemId String    @unique
  description      String
  category         String?
  note             String?
  reportedById     String?
  reportedByName   String?
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?
  deletedAt        DateTime?

  @@index([organizationId])
  @@index([propertyId])
  @@map("lease_violations")
}

// ─── Suggestion ─────────────────────────────────────────

model Suggestion {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  userName       String
  userEmail      String
  text           String
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("suggestions")
}

// ─── Photo ──────────────────────────────────────────────

model Photo {
  id                String  @id @default(cuid())
  url               String
  key               String
  inspectionItemId  String?
  maintenanceItemId String?
  createdAt         DateTime @default(now())

  inspectionItem  InspectionItem?  @relation(fields: [inspectionItemId], references: [id])
  maintenanceItem MaintenanceItem? @relation(fields: [maintenanceItemId], references: [id])

  @@index([inspectionItemId])
  @@index([maintenanceItemId])
  @@map("photos")
}
