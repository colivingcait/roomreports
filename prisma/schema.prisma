generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  OWNER
  PM
  CLEANER
  HANDYPERSON
  RESIDENT
  OTHER
}

enum InspectionType {
  COMMON_AREA
  COMMON_AREA_QUICK
  ROOM_TURN
  QUARTERLY
  RESIDENT_SELF_CHECK
  MOVE_IN_OUT
}

enum InspectionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// ─── Organization ───────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users       User[]
  properties  Property[]
  inspections Inspection[]
  maintenanceItems MaintenanceItem[]
  invitations Invitation[]
  vendors     Vendor[]

  @@map("organizations")
}

// ─── User ───────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String?
  googleId       String?  @unique
  role           Role
  customRole     String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id])
  sessions            Session[]
  inspections         Inspection[]
  propertyAssignments PropertyAssignment[]
  sentInvitations     Invitation[]         @relation("InvitedByUser")
  assignedMaintenance MaintenanceItem[]    @relation("AssignedUser")

  @@index([organizationId])
  @@map("users")
}

// ─── Session ────────────────────────────────────────────

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Invitation ─────────────────────────────────────────

model Invitation {
  id             String   @id @default(cuid())
  email          String
  role           Role
  token          String   @unique
  organizationId String
  propertyId     String?
  roomId         String?
  invitedById    String
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  room         Room?        @relation(fields: [roomId], references: [id])
  invitedBy    User         @relation("InvitedByUser", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([token])
  @@map("invitations")
}

// ─── Property ───────────────────────────────────────────

model Property {
  id             String   @id @default(cuid())
  name           String
  address        String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id])
  rooms               Room[]
  kitchens            Kitchen[]
  bathrooms           Bathroom[]
  inspections         Inspection[]
  maintenanceItems    MaintenanceItem[]
  propertyAssignments PropertyAssignment[]
  invitations         Invitation[]

  @@index([organizationId])
  @@map("properties")
}

// ─── Room ───────────────────────────────────────────────

model Room {
  id        String   @id @default(cuid())
  label     String
  features  String[]
  furniture String[]
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  property         Property          @relation(fields: [propertyId], references: [id])
  inspections      Inspection[]
  maintenanceItems MaintenanceItem[]
  invitations      Invitation[]

  @@index([propertyId])
  @@map("rooms")
}

// ─── Kitchen ────────────────────────────────────────────

model Kitchen {
  id         String   @id @default(cuid())
  label      String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@map("kitchens")
}

// ─── Bathroom ───────────────────────────────────────────

model Bathroom {
  id         String   @id @default(cuid())
  label      String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@map("bathrooms")
}

// ─── PropertyAssignment ─────────────────────────────────

model PropertyAssignment {
  id         String @id @default(cuid())
  userId     String
  propertyId String

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
  @@map("property_assignments")
}

// ─── Inspection ─────────────────────────────────────────

model Inspection {
  id             String           @id @default(cuid())
  type           InspectionType
  status         InspectionStatus @default(DRAFT)
  propertyId     String
  roomId         String?
  inspectorId    String
  inspectorName  String
  inspectorRole  Role
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  completedAt    DateTime?
  deletedAt      DateTime?

  property         Property          @relation(fields: [propertyId], references: [id])
  room             Room?             @relation(fields: [roomId], references: [id])
  inspector        User              @relation(fields: [inspectorId], references: [id])
  organization     Organization      @relation(fields: [organizationId], references: [id])
  items            InspectionItem[]
  maintenanceItems MaintenanceItem[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([inspectorId])
  @@map("inspections")
}

// ─── InspectionItem ─────────────────────────────────────

model InspectionItem {
  id               String   @id @default(cuid())
  inspectionId     String
  zone             String
  text             String
  options          String[]
  status           String
  flagCategory     String?
  note             String?
  isMaintenance    Boolean  @default(false)
  isLeaseViolation Boolean  @default(false)
  priority         String?
  entryCode        String?
  entryApproved    Boolean  @default(false)
  createdAt        DateTime @default(now())

  inspection      Inspection       @relation(fields: [inspectionId], references: [id])
  maintenanceItem MaintenanceItem?
  photos          Photo[]

  @@index([inspectionId])
  @@map("inspection_items")
}

// ─── MaintenanceItem ────────────────────────────────────

model MaintenanceItem {
  id                String            @id @default(cuid())
  inspectionItemId  String?           @unique
  inspectionId      String?
  propertyId        String
  roomId            String?
  organizationId    String
  description       String
  zone              String
  status            MaintenanceStatus @default(OPEN)
  assignedTo        String?           // free-text (custom / legacy)
  assignedUserId    String?
  assignedVendorId  String?
  flagCategory      String
  note              String?
  priority          String?           // Low | Medium | High
  estimatedCost     Float?
  actualCost        Float?
  vendor            String?
  entryApproved     Boolean           @default(false)
  entryApprovedAt   DateTime?
  entryCode         String?
  reportedById      String?
  reportedByName    String?
  reportedByRole    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  resolvedAt        DateTime?
  deletedAt         DateTime?

  inspectionItem  InspectionItem?         @relation(fields: [inspectionItemId], references: [id])
  inspection      Inspection?             @relation(fields: [inspectionId], references: [id])
  property        Property                @relation(fields: [propertyId], references: [id])
  room            Room?                   @relation(fields: [roomId], references: [id])
  organization    Organization            @relation(fields: [organizationId], references: [id])
  assignedUser    User?                   @relation("AssignedUser", fields: [assignedUserId], references: [id])
  assignedVendor  Vendor?                 @relation(fields: [assignedVendorId], references: [id])
  photos          Photo[]
  attachments     MaintenanceAttachment[]
  events          MaintenanceEvent[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([status])
  @@index([assignedVendorId])
  @@index([assignedUserId])
  @@map("maintenance_items")
}

// ─── Vendor ─────────────────────────────────────────────

model Vendor {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  company        String?
  phone          String?
  email          String?
  specialties    String[] // FLAG_CATEGORIES values
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization        Organization      @relation(fields: [organizationId], references: [id])
  assignedMaintenance MaintenanceItem[]

  @@index([organizationId])
  @@map("vendors")
}

// ─── MaintenanceAttachment ──────────────────────────────

model MaintenanceAttachment {
  id                String   @id @default(cuid())
  maintenanceItemId String
  url               String
  key               String
  label             String   // quote | receipt | invoice | other
  originalName      String
  contentType       String?
  createdAt         DateTime @default(now())

  maintenance MaintenanceItem @relation(fields: [maintenanceItemId], references: [id])

  @@index([maintenanceItemId])
  @@map("maintenance_attachments")
}

// ─── MaintenanceEvent ───────────────────────────────────

model MaintenanceEvent {
  id                String   @id @default(cuid())
  maintenanceItemId String
  type              String   // created | status | assigned | priority | note | cost | vendor | attachment | resolved | reopened
  fromValue         String?
  toValue           String?
  note              String?
  byUserId          String?
  byUserName        String?
  createdAt         DateTime @default(now())

  maintenance MaintenanceItem @relation(fields: [maintenanceItemId], references: [id])

  @@index([maintenanceItemId])
  @@map("maintenance_events")
}

// ─── LeaseViolation ─────────────────────────────────────

model LeaseViolation {
  id               String    @id @default(cuid())
  organizationId   String
  propertyId       String
  roomId           String?
  inspectionId     String
  inspectionItemId String    @unique
  description      String
  category         String?
  note             String?
  reportedById     String?
  reportedByName   String?
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?
  deletedAt        DateTime?

  actions LeaseViolationAction[]

  @@index([organizationId])
  @@index([propertyId])
  @@map("lease_violations")
}

// ─── LeaseViolationAction ───────────────────────────────
// Follow-up actions logged against a violation (paper trail)

model LeaseViolationAction {
  id                String   @id @default(cuid())
  leaseViolationId  String
  organizationId    String
  method            String   // text | email | verbal | written_notice | other
  description       String
  actionAt          DateTime @default(now())
  loggedById        String?
  loggedByName      String?
  createdAt         DateTime @default(now())

  violation LeaseViolation @relation(fields: [leaseViolationId], references: [id])

  @@index([leaseViolationId])
  @@index([organizationId])
  @@map("lease_violation_actions")
}

// ─── Task ───────────────────────────────────────────────
// Admin task board — separate from MaintenanceItem

model Task {
  id               String     @id @default(cuid())
  organizationId   String
  title            String
  description      String?
  propertyId       String?
  assignedTo       String?
  assignedUserId   String?
  assignedVendorId String?
  dueAt            DateTime?
  priority         String?    // Low | Medium | High
  status           TaskStatus @default(TODO)
  createdById      String?
  createdByName    String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  completedAt      DateTime?
  deletedAt        DateTime?

  @@index([organizationId])
  @@index([propertyId])
  @@index([assignedUserId])
  @@index([assignedVendorId])
  @@index([status])
  @@map("tasks")
}

// ─── InspectionSchedule ─────────────────────────────────
// Recurrence rule per property + inspection type

model InspectionSchedule {
  id              String         @id @default(cuid())
  organizationId  String
  propertyId      String
  inspectionType  InspectionType
  frequencyDays   Int            // e.g. 7, 14, 30, 90
  startsOn        DateTime       @default(now())
  active          Boolean        @default(true)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([propertyId, inspectionType])
  @@index([organizationId])
  @@map("inspection_schedules")
}

// ─── InspectionTemplate ─────────────────────────────────
// Per-org, per-type customization of the built-in checklist.

model InspectionTemplate {
  id             String         @id @default(cuid())
  organizationId String
  inspectionType InspectionType
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  items InspectionTemplateItem[]

  @@unique([organizationId, inspectionType])
  @@map("inspection_templates")
}

model InspectionTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  zone       String
  text       String
  options    String[]
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("inspection_template_items")
}

// ─── Suggestion ─────────────────────────────────────────

model Suggestion {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  userName       String
  userEmail      String
  text           String
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("suggestions")
}

// ─── Photo ──────────────────────────────────────────────

model Photo {
  id                String  @id @default(cuid())
  url               String
  key               String
  inspectionItemId  String?
  maintenanceItemId String?
  createdAt         DateTime @default(now())

  inspectionItem  InspectionItem?  @relation(fields: [inspectionItemId], references: [id])
  maintenanceItem MaintenanceItem? @relation(fields: [maintenanceItemId], references: [id])

  @@index([inspectionItemId])
  @@index([maintenanceItemId])
  @@map("photos")
}
